{
  "expo": {
    "name": "PacketFlow Mobile App",
    "slug": "packetflow-app",
    "version": "1.0.27",
    "orientation": "portrait",
    "scheme": "packetflow",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "buildNumber": "1",
      "bundleIdentifier": "com.packetflow.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "predictiveBackGestureEnabled": false,
      "versionCode": 1,
      "package": "com.packetflow.app"
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-asset",
      "expo-sqlite",
      "expo-font",
      "expo-system-ui",
      "expo-sharing",
      "expo-file-system"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}